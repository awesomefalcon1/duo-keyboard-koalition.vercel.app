# Supabase Local Development Configuration
# Copy this file to .env.local
# Run: npx supabase start to generate actual credentials

# Supabase API URL (default port 54321)
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321

# Supabase Anon Key (public, used in browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-from-supabase-start

# Service Role Key (private, server-side only - DO NOT EXPOSE)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-from-supabase-start

# Database Connection URL (for direct DB access)
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# Environment
NODE_ENV=development

# For production, replace with your Supabase project credentials:
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-production-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-production-service-role-key
